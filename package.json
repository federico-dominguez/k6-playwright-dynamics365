{
  "name": "k6-playwright-dynamics365",
  "version": "1.0.0",
  "description": "Performance & Automation Testing Framework for Microsoft Dynamics 365 CE using k6 and Playwright",
  "main": "dist/index.js",
  "scripts": {
    "build": "webpack",
    "build:watch": "webpack --watch",
    "test:protocol": "powershell -ExecutionPolicy Bypass -File ./scripts/run-test.ps1 protocol",
    "test:browser": "powershell -ExecutionPolicy Bypass -File ./scripts/run-test.ps1 browser",
    "test:login": "powershell -ExecutionPolicy Bypass -File ./scripts/run-test.ps1 login",
    "test": "npm run test:protocol",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "keywords": [
    "k6",
    "playwright",
    "dynamics365",
    "performance-testing",
    "load-testing",
    "automation"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/k6": "^0.54.0",
    "prettier": "^3.2.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.3.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0"
  }
}
