# ===========================================
# Dynamics 365 Connection Settings
# ===========================================

# Your Dynamics 365 organization URL
D365_ORG_URL=https://your-org.crm.dynamics.com

# Azure AD App Registration credentials
D365_CLIENT_ID=your-client-id
D365_CLIENT_SECRET=your-client-secret
D365_TENANT_ID=your-tenant-id

# ===========================================
# Test Configuration
# ===========================================

# Environment: dev | staging | prod
TEST_ENVIRONMENT=dev

# Enable k6 browser module (requires Chrome/Chromium)
K6_BROWSER_ENABLED=true

# Default test timeout in milliseconds
TEST_TIMEOUT_MS=60000

# ===========================================
# Optional: Grafana Cloud Integration
# ===========================================

# K6_CLOUD_TOKEN=your-k6-cloud-token
# K6_CLOUD_PROJECT_ID=your-project-id
